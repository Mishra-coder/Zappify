{
    "family": "zappify-frontend",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "zappify-frontend",
            "image": "185259096541.dkr.ecr.us-east-1.amazonaws.com/zappify-frontend:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/zappify-frontend",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [ "CMD-SHELL", "wget -qO- http://localhost/health || exit 1" ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 10
            }
        }
    ],
    "requiresCompatibilities": [ "FARGATE" ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::185259096541:role/LabRole",
    "taskRoleArn": "arn:aws:iam::185259096541:role/LabRole"
}
